{
  "manifest_version": 3,
  "name": "Copy All Tab URLs",
  "version": "1.3",
  "description": "Click the toolbar icon to copy URLs of all open tabs to the clipboard (one per line).",
  "permissions": ["scripting", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Copy links",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
